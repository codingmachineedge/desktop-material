{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "desktop-material-app",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "cross-env",
        "NODE_ENV=development",
        "PORT=3001",
        "ts-node",
        "-P",
        "script/tsconfig.json",
        "script/start.ts"
      ],
      "port": 3001
    },
    {
      "name": "remote-site",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "remote-site", "run", "dev"],
      "port": 3000
    }
  ]
}
